# Verify branch name format before pushing
BRANCH=$(git symbolic-ref --short HEAD)
ALLOWED="^(main|develop|staging|(hotfix|release)/.+)$"
REQUIRED="^TESIS-[0-9]+-[a-z0-9-]+$"

if ! echo "$BRANCH" | grep -qE "$ALLOWED" && ! echo "$BRANCH" | grep -qE "$REQUIRED"; then
  echo ""
  echo "❌ Branch name '$BRANCH' is not valid."
  echo "   Use the format: TESIS-<number>-short-description"
  echo "   Example:        TESIS-123-user-authentication"
  echo "   Allowed special branches: main, develop, staging, hotfix/*, release/*"
  echo ""
  exit 1
fi

# Run full lint and format check before pushing
npm run lint
npm run format:check
